# Server
PORT=8000
HOST=127.0.0.1

# Chrome Extension
# Find your extension ID at chrome://extensions with Developer Mode enabled
EXTENSION_ID=your_extension_id_here
EXTENSION_API_KEY=your_api_key_here

# Telegram
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal Telegram user ID (use @userinfobot to find it)
TELEGRAM_USER_ID=your_telegram_user_id_here
# Random secret used to verify Telegram webhook requests
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# Google Calendar
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Database
# Use :memory: for in-memory SQLite (default) or a file path for persistence
DATABASE_PATH=:memory:
